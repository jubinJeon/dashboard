# ── 백엔드(server.js) 환경변수 ─────────────────────────────────
# Coolify > Environment Variables 에 동일하게 등록하세요. (절대 커밋 금지)

# Azure AD (client credentials)
AZURE_TENANT_ID=94d56da1-db03-450a-a441-7717e2920e48
AZURE_CLIENT_ID=87ea8880-8a12-40f6-9b8e-108e1a068948
AZURE_CLIENT_SECRET=여기에_재발급한_시크릿
AZURE_SCOPE=https://analysis.windows.net/powerbi/api/.default

# Microsoft Fabric GraphQL 엔드포인트
GRAPHQL_URL=https://03f3befb55624cccb4379c1ca6018005.z03.graphql.fabric.microsoft.com/v1/workspaces/03f3befb-5562-4ccc-b437-9c1ca6018005/graphqlapis/31c874be-ef59-4e18-bd69-e4fd365dc329/graphql

# 서버 포트 (Coolify 가 자동 주입할 수도 있음)
PORT=3001

# 회사 SSL 인터셉션 환경에서 TLS 검증 우회 (필요 시)
NODE_TLS_REJECT_UNAUTHORIZED=0

# ── 프론트엔드(선택) ───────────────────────────────────────────
# 보통 비워두면 됨. API 가 다른 오리진일 때만 설정.
# VITE_API_URL=/api/graphql
